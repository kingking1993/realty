# 공공데이터포털 (data.go.kr) "아파트 매매 실거래가 자료" 서비스 키 (Decoding 키 사용)
MOLIT_API_KEY=

# 네이버 개발자센터 (developers.naver.com) 검색 API 애플리케이션
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# (선택) 설정하면 전체 화면이 이 비밀번호로 보호됨 — 클라우드 배포 시 필수
APP_PASSWORD=

# (선택) 외부 DB 사용 시 (예: Neon Postgres). 비우면 로컬 SQLite (data/realty.db)
DATABASE_URL=

# (선택) 1이면 내부 자동수집 스케줄러 끔 — 외부 크론을 쓰는 클라우드 배포용
DISABLE_SCHEDULER=
